# ── Frontend Environment Variables ────────────────────────────────────────────
# Copy this file to .env.local for local dev (Vite proxy handles /api automatically)
# Set these in Netlify: Site settings → Environment variables

# Your Render backend URL (set after deploying backend)
VITE_API_URL=https://YOUR-SERVICE-NAME.onrender.com/api

# App name (optional)
VITE_APP_NAME=AA Dream Wave
